# HLS MCP Server environment variables
# Copy this to .env — never commit .env to git

# ═══════════════════════════════════════════════════════════════
# REQUIRED SETTINGS
# ═══════════════════════════════════════════════════════════════

# Your HLS CRM base URL (no trailing slash)
HLS_BASE_URL=https://dev.helloleads.io

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION MODE
# ═══════════════════════════════════════════════════════════════

# Option 1: Static Credentials (for local development/testing)
# Get these by calling /mcplogin once and copying the response
HLS_TOKEN=d62519a9f2f19394914a025eaf0d66b7
HLS_USER_ID=86426

# Option 2: OAuth2 (for production/Claude integration)
# Uncomment this to enable OAuth authentication:
OAUTH_ENABLED=1

# ═══════════════════════════════════════════════════════════════
# SERVER SETTINGS
# ═══════════════════════════════════════════════════════════════

# Port for the HTTP+SSE server
PORT=3000

# ═══════════════════════════════════════════════════════════════
# HTTPS/SSL CONFIGURATION (Required for OAuth)
# ═══════════════════════════════════════════════════════════════

# Enable HTTPS (required when OAUTH_ENABLED=1)
# USE_HTTPS=1

# Option A: Separate key and certificate files
# HTTPS_KEY_PATH=/path/to/privkey.pem
# HTTPS_CERT_PATH=/path/to/fullchain.pem

# Option B: PFX/P12 bundle file
# HTTPS_PFX_PATH=/path/to/certificate.pfx
# HTTPS_PASSPHRASE=your_pfx_password_if_encrypted
