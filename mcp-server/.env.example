# HelloLeads MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of your HelloLeads application (no trailing slash)
HLS_BASE_URL=https://your-helloleads-domain.com

# Your HelloLeads API key  (find it under Settings → API in the web app)
HLS_API_KEY=your_hls_api_key_here

# The email address of the account owner / API user
HLS_EMAIL=owner@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────

# Default organisation ID — tools use this when no organizationId is supplied.
# If left blank the caller must always pass organizationId explicitly.
HLS_ORG_ID=
